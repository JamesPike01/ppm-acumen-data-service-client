<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>PPM.Acumen.DataService.Client</PackageId>
    <Version>1.0.0</Version>
    <Authors>Deltek</Authors>
    <Company>Deltek</Company>
    <Product>PPM Acumen Data Service Client</Product>
    <Description>HTTP client library for the ppm-acumen-data-service REST API. Provides typed access to workbook import, export, and management endpoints.</Description>
  </PropertyGroup>

  <PropertyGroup>
    <AddDigitalSignature>true</AddDigitalSignature>
    <GenerateTypeLibrary>true</GenerateTypeLibrary>
    <PerformObfuscation>false</PerformObfuscation>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="6.0.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="System.ComponentModel.Annotations" Version="5.0.0" />
  </ItemGroup>

</Project>
